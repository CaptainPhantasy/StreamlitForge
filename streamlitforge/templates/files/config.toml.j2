[server]
port = {{ port | default(8501) }}
headless = true
runOnSave = true

[theme]
primaryColor = "{{ primary_color | default('#FF4B4B') }}"
backgroundColor = "{{ bg_color | default('#FFFFFF') }}"
secondaryBackgroundColor = "{{ secondary_bg | default('#F0F2F6') }}"
textColor = "{{ text_color | default('#262730') }}"
